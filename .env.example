# Server config — copy to .env and fill in real values.
# Server scope: auth + presence + P2P matchmaking metadata + binaries.
# Zero user payload stored. No billing (free, P2P-only).

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://progsoft:change-me@localhost:5432/progsoft
PORT=3469

# ── Admin bootstrap ────────────────────────────────────────
ADMIN_KEY=change-me-admin-secret
ADMIN_EMAIL=admin@admin.com
ADMIN_DEFAULT_PASSWORD=changeme123

# ── Auth (use long random strings in prod) ─────────────────
JWT_SECRET=change-me-to-a-long-random-string
CSRF_SECRET=change-me-to-another-long-random-string
FORGE_KEK_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── CORS ───────────────────────────────────────────────────
# Production: desktop app runs locally — set Tauri origin or "*" for now.
# Development: http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# ── SMTP (password reset emails) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ai.progsoft.eu
APP_URL=https://ai.progsoft.eu

# ── PostgreSQL (docker-compose only) ───────────────────────
POSTGRES_USER=progsoft
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=progsoft

# ── Optional: OpenTelemetry tracing ────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com
# OTEL_SERVICE_NAME=monkey-server
