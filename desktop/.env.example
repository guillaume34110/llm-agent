# Desktop client — copy to .env and adjust as needed.
# Two backends architecture (local-first, cloud only for billing).

# Local Tauri sidecar (Python binary spawned by main.rs).
# Handles: model catalog mirror, sessions, workspace, offline cache.
# Always localhost in production (sidecar runs in Tauri process).
VITE_SIDECAR_URL=http://localhost:3471

# Cloud NestJS backend.
# Handles: auth + Stripe billing + /api/llm/chat + /api/llm/embed (OpenRouter
# bridge with token-based billing) + binary downloads + model catalog.
# Production: https://ai.progsoft.eu
# Dev:        http://localhost:3469
VITE_BACKEND_URL=https://ai.progsoft.eu
