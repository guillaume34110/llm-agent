# Production build config (loaded by `vite build`, mode=production).
# Dev `.env` stays on localhost; this file overrides only for the prod DMG.

# Local Tauri sidecar (always localhost, spawned by main.rs).
VITE_SIDECAR_URL=http://localhost:3471

# Cloud NestJS backend — production.
VITE_BACKEND_URL=https://ai.progsoft.eu
