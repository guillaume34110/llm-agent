{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Monkey desktop",
  "windows": ["main"],
  "permissions": [
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "core:window:allow-set-size",
    "core:window:allow-set-min-size",
    "core:window:allow-set-max-size",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-position",
    "core:window:allow-center",
    "core:window:allow-inner-size",
    "core:window:allow-scale-factor",
    "core:window:allow-outer-position",
    "core:window:allow-set-focus",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "zsh", "cmd": "zsh", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "zsh", "cmd": "zsh", "args": true }
      ]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:scope-home-recursive",
    "fs:scope-temp-recursive",
    "fs:scope-document-recursive",
    "fs:scope-download-recursive",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://ai.progsoft.eu/*" },
        { "url": "https://api.ipify.org/*" },
        { "url": "https://huggingface.co/*" },
        { "url": "https://cdn-lfs.huggingface.co/*" },
        { "url": "https://cdn-lfs-us-1.huggingface.co/*" },
        { "url": "http://localhost:3469/*" },
        { "url": "http://localhost:3471/*" },
        { "url": "http://localhost:3472/*" },
        { "url": "http://127.0.0.1:3472/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*/*" }
      ]
    }
  ]
}
